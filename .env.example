# =====================================================================
# Café Inventory & Replenishment — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# All Unleashed credentials live ONLY here on the backend.
# =====================================================================

# --- App ---
APP_ENV=local                       # local | production
SECRET_KEY=change-me-to-a-long-random-string   # signs session cookies
BASE_URL=http://localhost:8000      # used to build /scan/{tag_id} QR links

# One-time bootstrap for hosts without a shell (e.g. Railway): set to true for
# the FIRST deploy to seed stores/products/users on boot (idempotent), then
# remove it. Equivalent to running `python -m scripts.seed`.
SEED_ON_STARTUP=false

# --- Database ---
# Local default is SQLite (no server needed). For production use Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/cafeinv
DATABASE_URL=sqlite:///./cafe_inventory.db

# --- Unleashed API (BACKEND ONLY — never expose to the browser) ---
UNLEASHED_API_ID=your-unleashed-api-id
UNLEASHED_API_KEY=your-unleashed-api-key
UNLEASHED_API_URL=https://api.unleashedsoftware.com

# The physical warehouse that FULFILLS replenishment orders.
# (Stores are NOT warehouses — they are Unleashed *customers*. The order still
#  needs a source warehouse to ship from.)
UNLEASHED_FULFILL_WAREHOUSE_CODE=MAIN

# Sales Orders created via the API may only be "Parked" or "Completed".
# We create as "Parked"; warehouse staff progress it to Completed in Unleashed.
UNLEASHED_CREATE_ORDER_STATUS=Parked

# Optional defaults applied to created Sales Orders. Leave blank to inherit the
# customer's defaults in Unleashed (recommended unless your account requires them).
UNLEASHED_DEFAULT_CURRENCY=          # e.g. USD
UNLEASHED_DEFAULT_TAX_CODE=          # e.g. NONE / G.S.T.

# Receipt strategy when an order is Completed.
#   true  = read actual shipped quantities from Sales Shipments (preferred)
#   false = trust completed Sales Order line quantities (fallback; only safe if a
#           "Completed" order is guaranteed to mean fully delivered)
UNLEASHED_RECEIPT_USE_SHIPMENTS=true
# If shipments are enabled but none are found for a completed order, fall back to
# the order line quantities instead of leaving the receipt unprocessed.
UNLEASHED_RECEIPT_FALLBACK_TO_ORDER=true

# --- Webhooks ---
# Shared secret you set when registering the Unleashed webhook subscription.
# Incoming webhook calls must present it (header or query) or they are rejected.
UNLEASHED_WEBHOOK_SECRET=change-me-webhook-secret

# --- Polling fallback ---
POLLING_ENABLED=true
POLLING_INTERVAL_MINUTES=10

# --- Live integration test (optional; see tests/test_unleashed_integration.py) ---
# Read-only live tests run with `pytest -m integration` once the API creds above
# are set. To also run the create->read round-trip (creates ONE reusable Parked
# draft order), set these:
# UNLEASHED_SANDBOX_WRITE=false
# UNLEASHED_TEST_CUSTOMER_CODE=KTOWN
# UNLEASHED_TEST_PRODUCT_CODE=OATMILK
